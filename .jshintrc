{
  "bitwise": true,
  "curly": true,
  "eqeqeq": true,
  "esversion": 11,
  "forin": true,
  "freeze": true,
  "latedef": "nofunc",
  "maxcomplexity": 10,
  "noarg": true,
  "nonbsp": true,
  "nonew": true,
  "undef": true,
  "unused": true,
  "node": true,
  "browser": true,
  "jquery": true,
  "devel": true,
  "strict": "implied",
  "globals": {
    "angular": false,
    "module": false,
    "require": false,
    "URLSearchParams": true,
    "saturne": false,
    "reedcrm": false,
    "window": true,
    "flatpickr": false,
    "Hammer": false,
    "SignaturePad": false
  }
}
